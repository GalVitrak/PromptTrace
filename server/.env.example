# PostgreSQL connection string (required for persistence).
# Replace USER / PASSWORD with real credentials - placeholders cause auth errors.
# Docker Compose example: postgresql://prompttrace:prompttrace@localhost:5432/prompttrace?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/prompttrace?schema=public"
#
# After setting DATABASE_URL, create the DB once:  npm run db:create
# Then apply tables:  npm run db:push   (or npx prisma migrate deploy)

# API server port
PORT=3001

# OpenAI-compatible API (optional - leave unset for demo/mock mode)
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Heretic local FastAPI provider (optional)
HERETIC_BASE_URL=http://localhost:8000
HERETIC_TIMEOUT_MS=60000
